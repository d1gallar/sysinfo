#!/bin/bash

set -e

# SysInfo Default Command
DEFAULT_CMD="info"

cmd="${1:-$DEFAULT_CMD}"
shift || true

# Colors

G='\033[0;32m'
B='\033[0;34m'
Y='\033[1;33m'
C='\033[0;36m'
NC='\033[0m'


# SysInfo Helpers

get_ip() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        ifconfig 2>/dev/null | grep "inet " | grep -v 127.0.0.1 | awk '{print $2}' | head -1
    else
        hostname -I 2>/dev/null | awk '{print $1}'
    fi
}

get_memory() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        total=$(sysctl -n hw.memsize 2>/dev/null)
        [[ -n "$total" ]] && echo "$((total/1024/1024/1024))GB RAM" || echo "N/A"
    else
        free -h | awk '/Mem:/ {print $3 " used / " $2}'
    fi
}

get_battery() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        local batt
        batt=$(pmset -g batt 2>/dev/null | grep -Eo "[0-9]+%" | head -1)

        if [[ -n "$batt" ]]; then
            echo "$batt"
        else
            echo "N/A"
        fi
    else
        if [[ -f /sys/class/power_supply/BAT0/capacity ]]; then
            cat /sys/class/power_supply/BAT0/capacity
        else
            echo "N/A"
        fi
    fi
}


# Sys Info Commmands

show_specs() {
    echo -e "${B}───────────────────────────────${NC}"
    echo -e "${B}         System Specs          ${NC}"
    echo -e "${B}───────────────────────────────${NC}"
    echo

    if [[ "$OSTYPE" == "darwin"* ]]; then
        # CP
        cpu=$(sysctl -n machdep.cpu.brand_string 2>/dev/null)
        cores=$(sysctl -n hw.physicalcpu 2>/dev/null)

        # Memory
        mem=$(sysctl -n hw.memsize 2>/dev/null)
        mem_gb=$((mem/1024/1024/1024))

        # Disk
        disk=$(df -h / | awk 'NR==2 {print $2}')

        # GPU (basic)
        gpu=$(system_profiler SPDisplaysDataType 2>/dev/null | grep "Chipset Model" | head -1 | cut -d: -f2 | xargs)

        # OS
        os=$(sw_vers -productVersion 2>/dev/null)
        kernel=$(uname -r)
        arch=$(uname -m)
        host=$(scutil --get ComputerName 2>/dev/null)

        echo -e "${G}CPU:        ${NC}${cpu:-N/A} (${cores} cores)"
        echo -e "${G}Memory:     ${NC}${mem_gb} GB"
        echo -e "${G}Disk:       ${NC}${disk}"
        echo -e "${G}GPU:        ${NC}${gpu:-N/A}"
        echo -e "${G}OS:         ${NC}macOS ${os}"
        echo -e "${G}Kernel:     ${NC}${kernel}"
        echo -e "${G}Arch:       ${NC}${arch}"
        echo -e "${G}Hostname:   ${NC}${host}"

    else
        # Linux fallback
        echo -e "${G}CPU:        ${NC}$(lscpu | grep 'Model name' | cut -d: -f2 | xargs)"
        echo -e "${G}Memory:     ${NC}$(free -h | awk '/Mem:/ {print $2}')"
        echo -e "${G}Disk:       ${NC}$(df -h / | awk 'NR==2 {print $2}')"
        echo -e "${G}OS:         ${NC}$(uname -o)"
        echo -e "${G}Kernel:     ${NC}$(uname -r)"
        echo -e "${G}Arch:       ${NC}$(uname -m)"
    fi

    echo
}

show_info() {
    echo -e "${B}───────────────────────────────${NC}"
    echo -e "${B}          System Info          ${NC}"
    echo -e "${B}───────────────────────────────${NC}"
    echo

    echo -e "${G}Time:    ${NC}$(date '+%Y-%m-%d %H:%M:%S')"
    echo -e "${B}User:    ${NC}$(whoami)@$(hostname -s)"
    echo -e "${Y}Uptime:  ${NC}$(uptime | awk -F'up ' '{print $2}' | cut -d',' -f1)"
    echo -e "${C}IP:      ${NC}$(get_ip)"
    echo -e "${G}Memory:  ${NC}$(get_memory)"

    battery=$(get_battery)
    [[ "$battery" != "N/A" ]] && echo -e "${Y}Battery: ${NC}$battery"

    if git rev-parse --git-dir &>/dev/null 2>&1; then
        echo -e "${B}Git:     ${NC}$(git branch --show-current 2>/dev/null)"
    fi

    echo -e "${C}Dir:     ${NC}$(pwd)"
    echo
}

show_help() {
    echo -e "${B}───────────────────────────────${NC}"
    echo -e "${B}           SysInfo Help        ${NC}"
    echo -e "${B}───────────────────────────────${NC}"
    echo

    echo -e "${G}Core Commands:${NC}"
    echo "  sysinfo            System overview (default)"
    echo "  sysinfo info       Same as default view"
    echo "  sysinfo specs      Hardware + OS details"
    echo

    echo -e "${G}Quick Stats:${NC}"
    echo "  sysinfo cpu        CPU usage + cores"
    echo "  sysinfo disk       Disk usage"
    echo "  sysinfo battery    Battery status"
    echo "  sysinfo network    Network + latency test"
    echo

    echo -e "${G}Utility:${NC}"
    echo "  sysinfo help       Show this help menu"
    echo
}

show_network() {
    echo -e "${B}───────────────────────────────${NC}"
    echo -e "${B}        Network Status         ${NC}"
    echo -e "${B}───────────────────────────────${NC}"
    echo

    # Test connectivity (Google DNS is standard)
    target="8.8.8.8"

    echo -e "${G}Testing connectivity...${NC}"

    if ping -c 1 -W 1000 "$target" &>/dev/null; then
        echo -e "${G}Internet:   ${NC}Connected ✓"

        # latency test
        latency=$(ping -c 4 "$target" | tail -1 | awk -F'/' '{print $5}')

        if [[ -n "$latency" ]]; then
            echo -e "${Y}Latency:    ${NC}${latency} ms"
        else
            echo -e "${Y}Latency:    ${NC}N/A"
        fi
    else
        echo -e "${R}Internet:   ${NC}Not reachable ✗"
    fi

    echo

    # DNS test
    echo -e "${C}DNS check...${NC}"
    dns_time=$( (time nslookup google.com >/dev/null 2>&1) 2>&1 | grep real | awk '{print $2}')

    if [[ -n "$dns_time" ]]; then
        echo -e "${C}DNS lookup: ${NC}${dns_time}"
    else
        echo -e "${C}DNS lookup: ${NC}N/A"
    fi

    echo
}


get_cpu() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        # CPU usage (macOS)
        usage=$(top -l 1 | grep "CPU usage" | awk '{print $3 + $5}')
        cores=$(sysctl -n hw.ncpu 2>/dev/null)

        if [[ -n "$usage" ]]; then
            echo "${usage}% used (${cores} cores)"
        else
            echo "N/A"
        fi
    else
        # Linux CPU usage
        usage=$(top -bn1 | grep "Cpu(s)" | awk '{print 100 - $8}')
        cores=$(nproc 2>/dev/null)

        echo "${usage}% used (${cores} cores)"
    fi
}

get_disk() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        df -h / | awk 'NR==2 {print $3 " used / " $2 " (" $5 " used)"}'
    else
        df -h / | awk 'NR==2 {print $3 " used / " $2 " (" $5 " used)"}'
    fi
}

get_battery() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        local batt status

        batt=$(pmset -g batt 2>/dev/null | grep -Eo "[0-9]+%" | head -1)
        status=$(pmset -g batt 2>/dev/null | grep -Eo "Charging|Discharging|AC Power")

        if [[ -n "$batt" ]]; then
            if [[ -n "$status" ]]; then
                echo "${batt} (${status})"
            else
                echo "${batt}"
            fi
        else
            echo "N/A"
        fi

    else
        if [[ -f /sys/class/power_supply/BAT0/capacity ]]; then
            cap=$(cat /sys/class/power_supply/BAT0/capacity)
            echo "${cap}%"
        else
            echo "N/A"
        fi
    fi
}

case "$cmd" in
    info)
        show_info
        ;;

    specs)
        show_specs
        ;;

    cpu)
        echo -e "${B}CPU:${NC} $(get_cpu)"
        ;;

    disk)
        echo -e "${B}Disk:${NC} $(get_disk)"
        ;;

    battery)
        echo -e "${B}Battery:${NC} $(get_battery)"
        ;;

    network)
        show_network
        ;;

    help|--help|-h)
        show_help
        ;;

    *)
        echo -e "${R}Unknown command:${NC} $cmd"
        echo
        show_help
        exit 1
        ;;
esac
